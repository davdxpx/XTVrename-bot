# ═══════════════════════════════════════════════════════════
#  𝕏TV MediaStudio™ - Environment Configuration
#  Copy this file to .env and fill in your values.
#  ⚠️  NEVER commit your real .env to version control!
# ═══════════════════════════════════════════════════════════


# ─── REQUIRED ────────────────────────────────────────────────
# The bot refuses to start without these five values.

# Bot token from @BotFather.
BOT_TOKEN=

# Telegram app credentials from https://my.telegram.org
API_ID=
API_HASH=

# MongoDB connection string. The free Atlas tier works fine:
#   https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MAIN_URI=

# Telegram user ID of the bot owner — only this user can open /admin.
CEO_ID=


# ─── OPTIONAL ────────────────────────────────────────────────
# Leave empty / defaulted for a minimal setup; add as you need them.

# Comma-separated Telegram user IDs of additional admins.
ADMIN_IDS=

# Set PUBLIC_MODE=true to open the bot to the public. Otherwise only
# CEO_ID (and ADMIN_IDS) can use it.
PUBLIC_MODE=false

# Verbose logs.
DEBUG_MODE=false

# Enables Movie/Series auto-detection, posters, and auto channel routing.
# The bot runs fine without it — the TMDb-dependent features show a
# friendly 🔒 notice. Get a free key at:
#   https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Fernet key used to encrypt Mirror-Leech provider credentials at rest.
# Required only once you enable Mirror-Leech. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ⚠️  Back this up — losing it means users have to re-link providers.
SECRETS_KEY=
