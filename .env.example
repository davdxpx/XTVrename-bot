# ═══════════════════════════════════════════════════════════
#  𝕏TV MediaStudio™ - Environment Configuration
#  Copy this file to .env and fill in your values.
#  ⚠️  NEVER commit your real .env to version control!
# ═══════════════════════════════════════════════════════════


# ── TELEGRAM CREDENTIALS ────────────────────────────────────

BOT_TOKEN=
API_ID=
API_HASH=


# ── DATABASE ─────────────────────────────────────────────────

# MongoDB connection string - Python 4.7+
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MAIN_URI=


# ── ACCESS CONTROL ───────────────────────────────────────────

# Telegram User ID of the bot owner.
CEO_ID=

# Comma-separated Telegram User IDs of additional admins.
ADMIN_IDS=


# ── METADATA ─────────────────────────────────────────────────
TMDB_API_KEY=


# ── MODE (true/false) ─────────────────────────────────────────────────────

PUBLIC_MODE=
DEBUG_MODE=False
